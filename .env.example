VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# The email address of your Supabase owner account.
# The login screen will only ask for a password; this email is filled in automatically.
VITE_OWNER_EMAIL=you@example.com

# Your display name, shown in the browser tab ("Alice's Sheets") and the library header.
# Leave empty or omit to show "ownSheets".
VITE_OWNER_NAME=
